# Escolha para onde enviar: telegram | whatsapp | ambos | nenhum
ENVIAR_PARA=nenhum

# Quantidade maxima de noticias por execucao
MAX_NOTICIAS=5

# Intervalo em horas para buscar noticias no scheduler
FETCH_INTERVAL_HOURS=4

# Timezone para consolidacao do resumo diario
TIMEZONE_NAME=America/Manaus

# Caminho do banco SQLite
DB_PATH=data/fofoqueiro.db

# Habilita gravacao em paralelo no PostgreSQL (true/false)
POSTGRES_ENABLED=false
# Configuracao do PostgreSQL (Docker Compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=passwowrd
POSTGRES_DB=database

# Lista de RSS separada por virgula
RSS_SOURCES=https://d24am.com/feed/,https://www.portaldoholanda.com.br/feed/,https://amazonasatual.com.br/feed/,https://portalmanausalerta.com.br/feed/

# Telegram
# Crie um bot com o BotFather e pegue o token
TELEGRAM_BOT_TOKEN=9999999999:AAAaaBBBbbbCCCcc1111111222222333333
# ID do chat ou usuario que vai receber a mensagem
TELEGRAM_CHAT_ID=999999999

# WhatsApp (CallMeBot)
# Numero no formato internacional, ex: 5592999999999
WHATSAPP_PHONE=
# API key gerada no CallMeBot
WHATSAPP_APIKEY=
